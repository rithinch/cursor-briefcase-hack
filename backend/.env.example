# Copy to .env and fill in values before running

# --- required ---
ANTHROPIC_API_KEY=sk-ant-...
JWT_SECRET=change-me-in-production

# --- database ---
# supabase connection string (use port 5432, not 6543)
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:5432/postgres

# --- rails (default: mock — no credentials needed) ---
RAILS_ENABLED=mock
# RAILS_ENABLED=wise
# RAILS_ENABLED=revolut
# RAILS_ENABLED=yapily
# RAILS_ENABLED=wise,yapily

WISE_API_KEY=
REVOLUT_API_KEY=
REVOLUT_CERT_PATH=
REVOLUT_KEY_PATH=
YAPILY_API_KEY=
YAPILY_API_SECRET=

# --- langsmith tracing (optional) ---
# Sign up at https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=pulp

# --- local dev ---
PULP_SEED_DEV_ACCOUNT=true
PULP_DEV_API_KEY=pk_test_dev

# --- azure blob storage (optional — invoice PDFs stored if configured) ---
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=invoices

# --- twilio whatsapp (optional — approval notifications sent if configured) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- optional overrides ---
LLM_MODEL=claude-sonnet-4-6
API_BASE_URL=http://localhost:8000
DEPLOYED_BASE_URL=  # public-facing URL prepended to approval links in WhatsApp messages (e.g. https://app.yoursite.com)
